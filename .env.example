# ── LocalStack / CDK Local ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

CDK_DEFAULT_ACCOUNT=000000000000
CDK_DEFAULT_REGION=us-east-1

LOCALSTACK_AUTH_TOKEN=

# ── Integration Tests ─────────────────────────────────────────────────
TABLE_NAME=person-local
EVENT_BUS_NAME=person-events-local
LOCALSTACK_ENDPOINT=http://localhost:4566

# ── Lambda Powertools (local development only) ───────────────────────
# Pretty-prints JSON logs in the terminal for readability
POWERTOOLS_DEV=true

# ── CDK ───────────────────────────────────────────────────────────────
CDK_DISABLE_LEGACY_EXPORT_WARNING=1

# ── LocalStack Container ──────────────────────────────────────────────
LOCALSTACK_DEBUG=0
